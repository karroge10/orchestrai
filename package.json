{
  "name": "orchestrai",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first Windows AI companion for diagnostics and approval-gated computer control",
  "author": "OrchestrAI Contributors",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder --win nsis",
    "pack": "npm run build && electron-builder --dir",
    "smoke:packaged": "powershell -NoProfile -ExecutionPolicy Bypass -File tests/packaged-smoke.ps1",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude tests/local-provider.integration.test.ts --exclude tests/*.e2e.test.ts --exclude tests/synthetic-e2e.test.ts",
    "test:local": "vitest run tests/local-provider.integration.test.ts --testTimeout=180000",
    "test:e2e": "vitest run tests/synthetic-e2e.test.ts tests/live-desktop.e2e.test.ts tests/live-browser.e2e.test.ts tests/diagnostics.e2e.test.ts --testTimeout=120000 --hookTimeout=30000",
    "report": "node scripts/finalize-report.mjs",
    "check": "npm run typecheck && npm test && npm audit --omit=dev",
    "check:local": "npm run check && npm run test:local"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.468.0",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.orchestrai.desktop",
    "productName": "OrchestrAI",
    "asar": true,
    "files": ["out/**/*", "package.json"],
    "extraResources": [{"from": "knowledge", "to": "knowledge", "filter": ["**/*.md"]}],
    "artifactName": "OrchestrAI-${version}-${arch}.${ext}",
    "win": {"target": [{"target": "nsis", "arch": ["x64"]}], "requestedExecutionLevel": "asInvoker", "icon": "build/icon.ico"},
    "nsis": {"oneClick": false, "allowToChangeInstallationDirectory": true, "perMachine": false, "createDesktopShortcut": true, "createStartMenuShortcut": true, "deleteAppDataOnUninstall": false},
    "publish": null
  }
}
